{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/admin/archive", "destination": "/admin.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
